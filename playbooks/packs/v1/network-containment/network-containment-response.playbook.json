{
  "id": "network-containment-response-v1",
  "name": "Network Containment: Segment Isolation Response",
  "description": "Triggered by an alert requiring network-level containment of a host or subnet. Coordinates firewall/security-group rule changes to block lateral movement while preserving forensics and management access.",
  "version": "1.0.0",
  "author": "Beenu - beenu@cyble.com",
  "tags": [
    "network-containment",
    "containment",
    "network",
    "mitre.t1562.001",
    "mitre.t1599"
  ],
  "trigger": {
    "on": "alert",
    "severity": ["high", "critical"],
    "tags": ["network-containment", "lateral-movement", "c2", "ransomware"]
  },
  "enabled": true,
  "dry_run_support": true,
  "created_at": "2026-05-10T08:00:00+00:00",
  "updated_at": "2026-05-10T08:00:00+00:00",
  "inputs": {
    "host_or_subnet": {
      "description": "Host IP or CIDR subnet to contain",
      "field": "alert.host",
      "required": true
    },
    "threat_type": {
      "description": "Threat driving the containment (ransomware, c2, lateral-movement)",
      "field": "alert.threat_type",
      "required": false
    },
    "allow_mgmt_ips": {
      "description": "Management IPs to keep allowed during containment",
      "field": "alert.mgmt_ips",
      "required": false
    }
  },
  "steps": [
    {
      "id": "e1",
      "name": "Enrich host reputation and asset context",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.host",
        "indicator_type": "ip"
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 30
    },
    {
      "id": "siem_search",
      "name": "Search SIEM for outbound connections from host",
      "type": "search_siem",
      "params": {
        "query": "src_ip={{inputs.host_or_subnet}} AND event_type=network",
        "time_window": "-6h",
        "max_results": 500
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 60
    },
    {
      "id": "approval_contain",
      "name": "Approval gate — apply network containment",
      "type": "approval",
      "params": {
        "message": "Apply network containment for '{{inputs.host_or_subnet}}'? This will block all east-west traffic except management access.",
        "approvers": ["soc-lead", "network-lead"],
        "timeout_seconds": 300,
        "auto_approve_severity": ["critical"]
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 320
    },
    {
      "id": "block_inbound_ip",
      "name": "Block inbound traffic to host via security group",
      "type": "block_ip",
      "params": {
        "ip_field": "alert.host",
        "direction": "inbound",
        "duration": "48h",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_contain.outcome == 'approved'",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "block_outbound_ip",
      "name": "Block outbound traffic from host via security group",
      "type": "block_ip",
      "params": {
        "ip_field": "alert.host",
        "direction": "outbound",
        "duration": "48h",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_contain.outcome == 'approved'",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "run_collection_script",
      "name": "Collect network flow evidence before isolation completes",
      "type": "run_script",
      "params": {
        "host_field": "alert.host",
        "script": "collect_netflow_evidence.sh",
        "args": ["--host", "{{inputs.host_or_subnet}}", "--output", "/forensics/{{alert.case_id}}/"],
        "dry_run": "{{dry_run}}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 60
    },
    {
      "id": "inv",
      "name": "Network containment investigation",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "network-containment"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify network and SOC teams",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "Network containment applied for {{inputs.host_or_subnet}} (threat: {{inputs.threat_type}}). Inbound blocked: {{context.block_inbound_success}}. Outbound blocked: {{context.block_outbound_success}}.",
        "service_key_env": "PD_NETWORK_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open network containment ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "Network Containment: {{inputs.host_or_subnet}} ({{inputs.threat_type}})",
        "queue": "soc",
        "labels": ["network-containment", "isolation"]
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}
