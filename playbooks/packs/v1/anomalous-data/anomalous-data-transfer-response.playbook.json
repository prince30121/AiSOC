{
  "id": "anomalous-data-transfer-response-v1",
  "name": "Anomalous Data Transfer: DLP / Exfiltration Response",
  "description": "Triggered by a DLP or UEBA alert detecting an anomalously large or out-of-policy data transfer, potential exfiltration to external destination, or sensitive data leaving the organization. Correlates evidence, blocks destination if malicious, and disables the user if compromise is confirmed.",
  "version": "1.0.0",
  "author": "Beenu - beenu@cyble.com",
  "tags": [
    "data-exfiltration",
    "dlp",
    "ueba",
    "anomalous-data",
    "insider-threat",
    "mitre.t1041",
    "mitre.t1048",
    "mitre.t1567"
  ],
  "trigger": {
    "on": "alert",
    "severity": ["high", "critical"],
    "tags": ["data-exfiltration", "dlp-violation", "anomalous-transfer", "insider-threat", "ueba"]
  },
  "enabled": true,
  "dry_run_support": true,
  "created_at": "2026-05-10T08:00:00+00:00",
  "updated_at": "2026-05-10T08:00:00+00:00",
  "inputs": {
    "user": {
      "description": "User responsible for the data transfer",
      "field": "alert.user",
      "required": true
    },
    "source_host": {
      "description": "Internal host where the transfer originated",
      "field": "alert.source_host",
      "required": false
    },
    "destination_ip": {
      "description": "External destination IP or domain",
      "field": "alert.destination_ip",
      "required": false
    },
    "data_volume_mb": {
      "description": "Volume of data transferred in megabytes",
      "field": "alert.data_volume_mb",
      "required": false
    },
    "data_classification": {
      "description": "Classification of the data (sensitive, confidential, pii, ip)",
      "field": "alert.data_classification",
      "required": false
    },
    "transfer_protocol": {
      "description": "Protocol used (https, ftp, sftp, email, usb, cloud)",
      "field": "alert.protocol",
      "required": false
    }
  },
  "steps": [
    {
      "id": "e1",
      "name": "Enrich destination IP / domain (threat intel)",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.destination_ip",
        "indicator_type": "ip",
        "skip_if_empty": true
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 30
    },
    {
      "id": "siem_search_user",
      "name": "Search SIEM for prior data transfer activity by user",
      "type": "search_siem",
      "params": {
        "query": "user={{inputs.user}} AND event_type=network_transfer",
        "time_window": "-30d",
        "max_results": 500
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 60
    },
    {
      "id": "siem_search_dest",
      "name": "Search SIEM for other users transferring to same destination",
      "type": "search_siem",
      "params": {
        "query": "dest_ip={{inputs.destination_ip}} AND event_type=network_transfer",
        "time_window": "-7d",
        "max_results": 200
      },
      "condition": "inputs.destination_ip != null",
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 45
    },
    {
      "id": "approval_block_dest",
      "name": "Approval gate — block destination IP",
      "type": "approval",
      "params": {
        "message": "Block destination IP '{{inputs.destination_ip}}' involved in anomalous data transfer ({{inputs.data_volume_mb}}MB, classification: {{inputs.data_classification}})?",
        "approvers": ["soc-lead", "data-security"],
        "timeout_seconds": 300,
        "auto_approve_severity": ["critical"]
      },
      "condition": "inputs.destination_ip != null",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 320
    },
    {
      "id": "block_dest_ip",
      "name": "Block destination IP at perimeter",
      "type": "block_ip",
      "params": {
        "ip_field": "alert.destination_ip",
        "duration": "72h",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_block_dest.outcome == 'approved' && inputs.destination_ip != null",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "approval_disable_user",
      "name": "Approval gate — disable user account",
      "type": "approval",
      "params": {
        "message": "Disable account for '{{inputs.user}}' due to suspected data exfiltration ({{inputs.data_volume_mb}}MB of {{inputs.data_classification}} data to {{inputs.destination_ip}})?",
        "approvers": ["soc-lead", "hr-security", "data-security"],
        "timeout_seconds": 600,
        "auto_approve_severity": ["critical"]
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 620
    },
    {
      "id": "disable_user",
      "name": "Disable user account (insider threat confirmed)",
      "type": "disable_user",
      "params": {
        "user_field": "inputs.user",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_disable_user.outcome == 'approved'",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "revoke_sessions",
      "name": "Revoke all active sessions for user",
      "type": "revoke_session",
      "params": {
        "user_field": "inputs.user",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_disable_user.outcome == 'approved'",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Data exfiltration investigation",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "data-exfiltration"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify data security and CISO",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "Anomalous data transfer by {{inputs.user}}: {{inputs.data_volume_mb}}MB of {{inputs.data_classification}} data via {{inputs.transfer_protocol}} to {{inputs.destination_ip}}. Destination blocked: {{context.block_success}}.",
        "service_key_env": "PD_CISO_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open data exfiltration ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "Anomalous Data Transfer: {{inputs.user}} — {{inputs.data_volume_mb}}MB {{inputs.data_classification}}",
        "queue": "soc",
        "labels": ["data-exfiltration", "dlp", "insider-threat"]
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}
