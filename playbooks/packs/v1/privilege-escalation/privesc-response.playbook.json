{
  "id": "privesc-response-v1",
  "name": "Privilege Escalation: Detection & Containment",
  "description": "Triggered by EDR or SIEM alert for privilege escalation activity (sudo abuse, token impersonation, LSASS dump, UAC bypass, etc.). Collects forensics, disables the account if confirmed malicious, and escalates to Tier-2 for post-exploitation review.",
  "version": "1.0.0",
  "author": "Beenu - beenu@cyble.com",
  "tags": [
    "privilege-escalation",
    "endpoint",
    "identity",
    "mitre.t1068",
    "mitre.t1548",
    "mitre.t1134"
  ],
  "trigger": {
    "on": "alert",
    "severity": ["high", "critical"],
    "tags": ["privilege-escalation", "privesc", "uac-bypass", "token-impersonation"]
  },
  "enabled": true,
  "dry_run_support": true,
  "created_at": "2026-05-10T08:00:00+00:00",
  "updated_at": "2026-05-10T08:00:00+00:00",
  "inputs": {
    "host": {
      "description": "Endpoint where privilege escalation was detected",
      "field": "alert.host",
      "required": true
    },
    "user": {
      "description": "User account performing the escalation",
      "field": "alert.user",
      "required": true
    },
    "technique": {
      "description": "MITRE ATT&CK technique ID (e.g. T1068)",
      "field": "alert.mitre_technique",
      "required": false
    },
    "process_name": {
      "description": "Offending process name",
      "field": "alert.process_name",
      "required": false
    }
  },
  "steps": [
    {
      "id": "e1",
      "name": "Search SIEM for prior activity by this user on this host",
      "type": "search_siem",
      "params": {
        "query": "user={{inputs.user}} AND host={{inputs.host}}",
        "time_window": "-24h",
        "max_results": 100
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 45
    },
    {
      "id": "av_scan",
      "name": "Run AV / EDR scan on host",
      "type": "run_av_scan",
      "params": {
        "host_field": "alert.host",
        "dry_run": "{{dry_run}}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 120
    },
    {
      "id": "collect_forensics",
      "name": "Collect forensic evidence via EDR script",
      "type": "run_script",
      "params": {
        "host_field": "alert.host",
        "script": "collect_privesc_evidence.sh",
        "args": ["--user", "{{inputs.user}}", "--process", "{{inputs.process_name}}", "--output", "/forensics/{{alert.case_id}}/"],
        "dry_run": "{{dry_run}}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 120
    },
    {
      "id": "approval_disable_user",
      "name": "Approval gate — disable user account",
      "type": "approval",
      "params": {
        "message": "Disable user account '{{inputs.user}}' due to privilege escalation on '{{inputs.host}}'?",
        "approvers": ["soc-lead", "identity-admin"],
        "timeout_seconds": 600,
        "auto_approve_severity": ["critical"]
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 620
    },
    {
      "id": "disable_user",
      "name": "Disable user account in IdP",
      "type": "disable_user",
      "params": {
        "user_field": "inputs.user",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_disable_user.outcome == 'approved'",
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "revoke_sessions",
      "name": "Revoke all active sessions for user",
      "type": "revoke_session",
      "params": {
        "user_field": "inputs.user",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_disable_user.outcome == 'approved'",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Privilege escalation investigation",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "privilege-escalation"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify SOC Tier-2",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "PrivEsc alert: {{inputs.user}} on {{inputs.host}} (technique: {{inputs.technique}}). Account disabled: {{context.disable_success}}.",
        "webhook_env": "SLACK_SOC_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open privilege escalation ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "PrivEsc: {{inputs.user}} on {{inputs.host}} ({{inputs.technique}})",
        "queue": "soc",
        "labels": ["privilege-escalation", "endpoint", "identity"]
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}
