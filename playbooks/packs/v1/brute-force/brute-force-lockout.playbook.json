{
  "id": "brute-force-lockout-v1",
  "name": "Brute Force: Account Lockout and Source Block",
  "description": "Triggered by detection of repeated failed authentication attempts (password spray, credential stuffing, RDP/SSH brute force). Locks out the targeted account, blocks the source IP, and triggers investigation.",
  "version": "1.0.0",
  "author": "Beenu - beenu@cyble.com",
  "tags": [
    "brute-force",
    "credential-stuffing",
    "password-spray",
    "authentication",
    "mitre.t1110",
    "mitre.t1110.001",
    "mitre.t1110.003"
  ],
  "trigger": {
    "on": "alert",
    "severity": ["medium", "high", "critical"],
    "tags": ["brute-force", "password-spray", "credential-stuffing", "rdp-brute", "ssh-brute"]
  },
  "enabled": true,
  "dry_run_support": true,
  "created_at": "2026-05-10T08:00:00+00:00",
  "updated_at": "2026-05-10T08:00:00+00:00",
  "inputs": {
    "user": {
      "description": "Targeted user account (may be null for password spray targeting many users)",
      "field": "alert.user",
      "required": false
    },
    "source_ip": {
      "description": "Attacking source IP or range",
      "field": "alert.source_ip",
      "required": true
    },
    "failure_count": {
      "description": "Number of failed authentication attempts that triggered this alert",
      "field": "alert.failure_count",
      "required": false
    },
    "target_service": {
      "description": "Service being brute-forced (ssh, rdp, web, vpn, idp)",
      "field": "alert.target_service",
      "required": false
    },
    "attack_type": {
      "description": "Type of brute-force attack (password-spray, credential-stuffing, dictionary)",
      "field": "alert.attack_type",
      "required": false
    }
  },
  "steps": [
    {
      "id": "e1",
      "name": "Enrich source IP (threat intel, reputation, ASN)",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.source_ip",
        "indicator_type": "ip"
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 30
    },
    {
      "id": "siem_search_src",
      "name": "Search SIEM for prior activity from attacking IP",
      "type": "search_siem",
      "params": {
        "query": "src_ip={{inputs.source_ip}}",
        "time_window": "-30d",
        "max_results": 200
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 45
    },
    {
      "id": "block_source_ip",
      "name": "Block attacking source IP at perimeter",
      "type": "block_ip",
      "params": {
        "ip_field": "alert.source_ip",
        "duration": "24h",
        "dry_run": "{{dry_run}}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "approval_disable_account",
      "name": "Approval gate — temporarily disable targeted account",
      "type": "approval",
      "params": {
        "message": "Temporarily disable account '{{inputs.user}}' due to brute-force attack ({{inputs.failure_count}} failures from {{inputs.source_ip}})?",
        "approvers": ["soc-lead", "identity-admin"],
        "timeout_seconds": 300,
        "auto_approve_severity": ["critical"]
      },
      "condition": "inputs.user != null",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 320
    },
    {
      "id": "disable_user",
      "name": "Temporarily disable targeted user account",
      "type": "disable_user",
      "params": {
        "user_field": "inputs.user",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_disable_account.outcome == 'approved' && inputs.user != null",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "revoke_sessions",
      "name": "Revoke active sessions for targeted user",
      "type": "revoke_session",
      "params": {
        "user_field": "inputs.user",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_disable_account.outcome == 'approved' && inputs.user != null",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "create_siem_notable",
      "name": "Create SIEM notable event for brute force campaign",
      "type": "create_notable_event",
      "params": {
        "title": "Brute Force: {{inputs.attack_type}} from {{inputs.source_ip}} targeting {{inputs.target_service}}",
        "severity": "high",
        "dry_run": "{{dry_run}}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Brute force investigation",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "brute-force"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify SOC and identity team",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "Brute force alert: {{inputs.attack_type}} from {{inputs.source_ip}} against {{inputs.target_service}} ({{inputs.failure_count}} failures). IP blocked: {{context.block_success}}. User disabled: {{context.disable_success}}.",
        "webhook_env": "SLACK_SOC_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open brute force ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P2",
        "title_template": "Brute Force: {{inputs.attack_type}} from {{inputs.source_ip}}",
        "queue": "soc",
        "labels": ["brute-force", "credential-attack", "authentication"]
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}
