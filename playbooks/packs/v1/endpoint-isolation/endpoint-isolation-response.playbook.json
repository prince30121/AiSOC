{
  "id": "endpoint-isolation-response-v1",
  "name": "Endpoint Isolation: EDR-Driven Host Quarantine",
  "description": "Triggered when an endpoint requires emergency isolation due to confirmed or high-confidence compromise (ransomware spread, active C2 communication, lateral movement staging). Uses EDR to network-isolate the host while preserving management connectivity, collects forensic artifacts, and notifies the SOC.",
  "version": "1.0.0",
  "author": "Beenu - beenu@cyble.com",
  "tags": [
    "endpoint-isolation",
    "edr",
    "quarantine",
    "host-isolation",
    "mitre.t1562.001",
    "mitre.t1204",
    "mitre.t1486"
  ],
  "trigger": {
    "on": "alert",
    "severity": ["high", "critical"],
    "tags": ["endpoint-isolation", "ransomware", "c2-communication", "lateral-movement", "host-compromise"]
  },
  "enabled": true,
  "dry_run_support": true,
  "created_at": "2026-05-10T08:00:00+00:00",
  "updated_at": "2026-05-10T08:00:00+00:00",
  "inputs": {
    "host": {
      "description": "Hostname or IP of the endpoint to isolate",
      "field": "alert.host",
      "required": true
    },
    "compromise_type": {
      "description": "Type of compromise driving isolation (ransomware, c2, lateral-movement, malware)",
      "field": "alert.threat_type",
      "required": false
    },
    "user": {
      "description": "User logged into the endpoint at time of alert",
      "field": "alert.user",
      "required": false
    },
    "ioc_hash": {
      "description": "IOC hash associated with the compromise, if known",
      "field": "alert.file_hash",
      "required": false
    },
    "parent_case_id": {
      "description": "Parent case ID for grouping related incidents",
      "field": "alert.case_id",
      "required": false
    }
  },
  "steps": [
    {
      "id": "e1",
      "name": "Enrich host asset context and existing alerts",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.host",
        "indicator_type": "host"
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 30
    },
    {
      "id": "e2",
      "name": "Enrich IOC hash (if available)",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.file_hash",
        "indicator_type": "hash",
        "skip_if_empty": true
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 30
    },
    {
      "id": "siem_search",
      "name": "Search SIEM for lateral movement indicators from this host",
      "type": "search_siem",
      "params": {
        "query": "src_host={{inputs.host}} AND (event_type=lateral_movement OR event_type=credential_dump OR event_type=network_scan)",
        "time_window": "-24h",
        "max_results": 300
      },
      "on_failure": "continue",
      "retry_max": 1,
      "timeout_seconds": 60
    },
    {
      "id": "collect_forensics",
      "name": "Collect forensic artifacts before isolation",
      "type": "run_script",
      "params": {
        "host_field": "alert.host",
        "script": "collect_forensic_artifacts.sh",
        "args": ["--host", "{{inputs.host}}", "--output", "/forensics/{{alert.case_id}}/", "--include", "processes,network,registry,events"],
        "dry_run": "{{dry_run}}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 120
    },
    {
      "id": "approval_isolate",
      "name": "Approval gate — network-isolate endpoint",
      "type": "approval",
      "params": {
        "message": "Network-isolate endpoint '{{inputs.host}}' (user: {{inputs.user}}) due to {{inputs.compromise_type}}? This will cut all network connectivity except EDR management channel.",
        "approvers": ["soc-lead"],
        "timeout_seconds": 300,
        "auto_approve_severity": ["critical"]
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 320
    },
    {
      "id": "isolate_host",
      "name": "Network-isolate host via EDR",
      "type": "isolate_host",
      "params": {
        "host_field": "alert.host",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.approval_isolate.outcome == 'approved'",
      "on_failure": "abort",
      "retry_max": 1,
      "timeout_seconds": 60
    },
    {
      "id": "block_ioc_hash",
      "name": "Block IOC hash globally across fleet",
      "type": "block_ioc",
      "params": {
        "indicator_type": "hash",
        "indicator_field": "alert.file_hash",
        "dry_run": "{{dry_run}}"
      },
      "condition": "inputs.ioc_hash != null",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "run_av_scan",
      "name": "Run AV scan on isolated host",
      "type": "run_av_scan",
      "params": {
        "host_field": "alert.host",
        "dry_run": "{{dry_run}}"
      },
      "condition": "steps.isolate_host.outcome == 'success'",
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 300
    },
    {
      "id": "inv",
      "name": "Endpoint isolation investigation",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "endpoint-compromise"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify SOC team and endpoint owner",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "Endpoint '{{inputs.host}}' isolated due to {{inputs.compromise_type}} (user: {{inputs.user}}). Forensics collected: {{context.forensics_success}}. IOC blocked: {{context.block_ioc_success}}.",
        "service_key_env": "PD_SOC_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open endpoint isolation ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "Endpoint Isolated: {{inputs.host}} — {{inputs.compromise_type}}",
        "queue": "soc",
        "labels": ["endpoint-isolation", "host-compromise", "edr"]
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}
